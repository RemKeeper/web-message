{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "web-message",
  "main": "./worker.mjs",
  "compatibility_date": "2026-07-17",
  "build": {
    "command": "npm run build"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "ChatRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ChatRoom"]
    }
  ]
}
